{
  "name": "subgraph-admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/subgraph-admin/src",
  "projectType": "application",
  "tags": ["scope:admin", "type:app"],
  "targets": {
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/subgraph-admin/package.json",
        "{workspaceRoot}/dist/apps/subgraph-admin/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/dist/apps/subgraph-admin/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "subgraph-admin:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "subgraph-admin:build:development"
        },
        "production": {
          "buildTarget": "subgraph-admin:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/subgraph-admin/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/src/generated"],
      "options": {
        "command": "node node_modules/@graphql-codegen/cli/cjs/bin.js --config {projectRoot}/codegen.ts",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
