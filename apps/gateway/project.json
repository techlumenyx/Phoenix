{
  "name": "gateway",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:gateway", "type:app"],
  "targets": {
    "serve": {
      "continuous": true,
      "executor": "nx:run-commands",
      "options": {
        "command": ".\\router.exe --config apps/gateway/router.yaml --supergraph apps/gateway/supergraph.graphql --log info --listen 0.0.0.0:4000",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "apps/gateway/jest.config.ts",
        "passWithNoTests": true
      }
    }
  }
}
