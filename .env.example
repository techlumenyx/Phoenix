# ============================================================
# CHRISTIAN LISTINGS — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# See docs/ENVIRONMENT.md for full documentation.

# Apollo Router binary — download from https://router.apollo.dev
# Windows: place router.exe in tools/bin/ after downloading
APOLLO_ROUTER_BIN=./tools/bin/router.exe
# ============================================================

# ----------------------------------------------------------
# SHARED — All backend services
# ----------------------------------------------------------

# Full MongoDB Atlas connection string (includes credentials)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net

# Firebase Admin SDK service account JSON, base64-encoded.
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Encode with: base64 -i serviceAccount.json (Mac/Linux) or certutil -encode (Windows)
FIREBASE_SERVICE_ACCOUNT_JSON=<base64-encoded-json>

# Shared high-entropy secret for authenticated subgraph-to-subgraph commands.
# Generate at least 32 random bytes and provide the same value to all subgraphs.
INTERNAL_SERVICE_KEY=<random-32-byte-secret>

# Internal HTTP base URLs used by the moderation workflow.
ADMIN_INTERNAL_URL=http://localhost:4004
CLASSIFIEDS_INTERNAL_URL=http://localhost:4003
IDENTITY_INTERNAL_URL=http://localhost:4001
EVENTS_INTERNAL_URL=http://localhost:4002

# Public URL used to build links in transactional emails.
PUBLIC_APP_URL=http://localhost:3000

# ----------------------------------------------------------
# EMAIL DELIVERY — admin orchestration + BullMQ worker
# Keep disabled until SendGrid sender/domain authentication is complete.
# ----------------------------------------------------------
EMAIL_ENABLED=false
EMAIL_PROVIDER=sendgrid
REDIS_URL=redis://localhost:6379
SENDGRID_API_KEY=<sendgrid-restricted-api-key>
SENDGRID_FROM_EMAIL=notifications@your-domain.example
SENDGRID_FROM_NAME=Christian Listings
SENDGRID_REPLY_TO=support@your-domain.example
SENDGRID_WEBHOOK_PUBLIC_KEY=<sendgrid-event-webhook-ecdsa-public-key>
EMAIL_WORKER_CONCURRENCY=5
EMAIL_MAX_ATTEMPTS=5
EMAIL_RETRY_DELAY_MS=5000
EMAIL_SCHEDULE_SCAN_MS=60000

# Comma-separated exact browser origins allowed to call the admin subgraph.
ADMIN_ALLOWED_ORIGINS=http://localhost:3001,https://christian-listings-admin.web.app,https://christian-listings-admin.firebaseapp.com
# Per-admin mutation ceiling per minute (minimum enforced value: 10).
ADMIN_RATE_LIMIT_PER_MINUTE=120
# Release identifiers surfaced on the read-only System Health page.
APP_VERSION=development
GIT_SHA=local

# ----------------------------------------------------------
# SUBGRAPH PORTS (set per service; Docker Compose handles this automatically)
# ----------------------------------------------------------
PORT=4001   # identity=4001, events=4002, classifieds=4003, admin=4004

# ----------------------------------------------------------
# MEDIA — identity, events, classifieds and admin media endpoints
# ----------------------------------------------------------

# Cloudinary credentials (cloud.cloudinary.com → Settings → Access Keys)
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>
CL_IDENTITY_MEDIA_URL=http://localhost:4001/media/upload
CL_EVENTS_MEDIA_URL=http://localhost:4002/media/upload
CL_CLASSIFIEDS_MEDIA_URL=http://localhost:4003/media/upload
CL_ADMIN_MEDIA_URL=http://localhost:4004/media/upload
CL_MEDIA_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ----------------------------------------------------------
# GATEWAY — Apollo Router subgraph routing URLs
# (These are set automatically in docker-compose.yml using Docker internal DNS)
# Only needed when running gateway outside Docker.
# ----------------------------------------------------------
SUBGRAPH_IDENTITY_URL=http://localhost:4001/graphql
SUBGRAPH_EVENTS_URL=http://localhost:4002/graphql
SUBGRAPH_CLASSIFIEDS_URL=http://localhost:4003/graphql
SUBGRAPH_ADMIN_URL=http://localhost:4004/graphql

# ----------------------------------------------------------
# BROWSER APPS (christian-listing + cl-admin — Webpack DefinePlugin)
# Must be prefixed CL_ to be injected into the browser bundle.
# Do not put secrets here.
# ----------------------------------------------------------

# Gateway URL the browser sends GraphQL requests to
CL_GRAPHQL_URL=http://localhost:4000/

# Firebase client config (from Firebase Console → Project Settings → Your apps → Web app)
CL_FIREBASE_API_KEY=AIzaSy<rest-of-key>
CL_FIREBASE_AUTH_DOMAIN=<project-id>.firebaseapp.com
CL_FIREBASE_PROJECT_ID=<project-id>
CL_FIREBASE_STORAGE_BUCKET=<project-id>.appspot.com
CL_FIREBASE_MESSAGING_SENDER_ID=<project-number>
CL_FIREBASE_APP_ID=1:<project-number>:web:<app-id>
