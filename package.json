{
  "name": "@christian-listings/source",
  "version": "0.0.0",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "build": "nx run-many --target=build --all",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "typecheck": "nx run-many --target=typecheck --all",
    "codegen": "nx run-many --target=codegen --all",
    "dev": "docker compose -f docker/docker-compose.yml -f docker/docker-compose.override.yml up",
    "dev:all": "nx run-many --target=serve --projects=subgraph-identity,subgraph-events,subgraph-classifieds,subgraph-admin,worker,gateway,christian-listing,cl-admin --parallel=8",
    "identity": "nx serve subgraph-identity",
    "events": "nx serve subgraph-events",
    "classifieds": "nx serve subgraph-classifieds",
    "admin": "nx serve subgraph-admin",
    "worker": "nx serve worker",
    "backend": "concurrently -n identity,events,classifieds,admin -c cyan,green,yellow,magenta npm:identity npm:events npm:classifieds npm:admin",
    "gateway": "nx serve gateway",
    "gateway:compose": "tools\\scripts\\compose-supergraph.bat",
    "cl": "nx serve christian-listing",
    "cl-admin": "nx serve cl-admin",
    "admin:provision": "tsx tools/scripts/provision-admin.ts",
    "admin:backup": "powershell -ExecutionPolicy Bypass -File tools/scripts/backup-admin.ps1",
    "frontend": "concurrently -n cl,cl-admin -c blue,red npm:cl npm:cl-admin",
    "seed:local": "node tools/scripts/seed-local-mongo.js",
    "seed:remote": "node tools/scripts/seed-local-mongo.js --remote"
  },
  "dependencies": {
    "@apollo/client": "^3.14.1",
    "@apollo/server": "^4.11.0",
    "@apollo/subgraph": "^2.8.0",
    "@as-integrations/fastify": "^2.1.1",
    "@sendgrid/eventwebhook": "^8.0.0",
    "@sendgrid/mail": "^8.1.6",
    "bullmq": "^5.80.9",
    "cloudinary": "^2.5.0",
    "fastify": "^4.29.1",
    "fastify-plugin": "^6.0.0",
    "fastify-raw-body": "^4.3.0",
    "firebase": "^10.14.0",
    "firebase-admin": "^12.7.0",
    "graphql": "^16.14.2",
    "ioredis": "^5.11.1",
    "mongoose": "^8.8.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@apollo/rover": "^0.41.0",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/client-preset": "^4.5.0",
    "@graphql-codegen/typescript": "^4.1.2",
    "@graphql-codegen/typescript-resolvers": "^4.4.1",
    "@nx/devkit": "23.0.0",
    "@nx/eslint": "23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/jest": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/node": "23.0.0",
    "@nx/playwright": "23.0.0",
    "@nx/react": "23.0.0",
    "@nx/vite": "23.0.0",
    "@nx/web": "23.0.0",
    "@nx/webpack": "23.0.0",
    "@playwright/test": "^1.37.0",
    "@pmmmwh/react-refresh-webpack-plugin": "^0.5.7",
    "@svgr/webpack": "^8.0.1",
    "@swc/helpers": "~0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.0",
    "firebase-tools": "^15.22.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "jest-util": "^29.7.0",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.0",
    "postcss": "^8.4.0",
    "prettier": "~3.6.2",
    "react-refresh": "^0.10.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.2.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "webpack": "^5.101.3",
    "webpack-bundle-analyzer": "^4.10.2",
